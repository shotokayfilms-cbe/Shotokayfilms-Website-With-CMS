---
layout: base.njk
title: Contact — Shot Okay Films
permalink: /contact/
---

<div class="page-header wrap">
  <span class="eyebrow mono">GET IN TOUCH</span>
  <h1>Let's shoot something</h1>
  <p>Tell us what you need below, or reach out directly — whichever's easier.</p>
</div>

<section class="quote">
  <div class="wrap">
    <div class="contact-grid">

      <div class="slip">
        <h2>Production request</h2>
        <p class="lead">Fill this in and we'll follow up on WhatsApp.</p>
        <form id="quoteForm">
          <div class="field">
            <label for="name">Name</label>
            <input type="text" id="name" required>
          </div>
          <div class="field">
            <label for="phone">Phone</label>
            <div class="phone-row">
              <span class="pfx">+91</span>
              <input type="tel" id="phone" placeholder="98765 43210" required>
            </div>
          </div>
          <div class="field">
            <label for="service">Service</label>
            <select id="service">
              {% for s in services.services %}
              <option value="{{ s.name }}">{{ s.name }}</option>
              {% endfor %}
              <option value="Something else">Something else</option>
            </select>
          </div>
          <div class="field">
            <label for="budget">Rough budget</label>
            <select id="budget">
              <option value="Under ₹25,000">Under ₹25,000</option>
              <option value="₹25,000 – ₹1,00,000">₹25,000 – ₹1,00,000</option>
              <option value="₹1,00,000 – ₹3,00,000">₹1,00,000 – ₹3,00,000</option>
              <option value="₹3,00,000+">₹3,00,000+</option>
            </select>
          </div>
          <div class="field">
            <label for="message">Anything else? (optional)</label>
            <textarea id="message" rows="3"></textarea>
          </div>
          <button type="button" class="submit-btn" id="sendBtn">Send Request</button>
        </form>
        <p class="form-note">Prefer to call? <a href="tel:+{{ site.phone_e164 }}">Tap here to call us directly</a></p>
      </div>

      <div class="contact-info">
        <div class="info-card">
          <span class="mono">DIRECT</span>
          <h3>Call or WhatsApp</h3>
          <p>Fastest way to reach us during studio hours.</p>
          <a class="info-link" href="tel:+{{ site.phone_e164 }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.5 2.1L8 10a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.9.6 2.9.7a2 2 0 0 1 1.7 2Z"/></svg>{{ site.phone_display }}</a>
          <a class="info-link" href="https://wa.me/{{ site.whatsapp }}" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 11.5a8.5 8.5 0 0 1-12.4 7.5L3 20l1.1-5.4A8.5 8.5 0 1 1 21 11.5Z"/></svg>WhatsApp us</a>
          <a class="info-link" href="mailto:{{ site.email }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2" <path d="m3 7 9 6 9-6"/></svg>{{ site.email }}</a>
</div>

        <div class="info-card">
          <span class="mono">STUDIO</span>
          <h3>Address &amp; hours</h3>
          <p>{{ site.address_line1 }}<br>{{ site.address_line2 }}</p>
          <p>{{ site.hours }}</p>
          <a class="map-link" href="{{ site.directions_url }}" target="_blank" rel="noopener">→ Get directions</a>
        </div>

        <div class="info-card">
          <span class="mono">FOLLOW</span>
          <h3>Social</h3>
          <div class="social-row">
            <a href="{{ site.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v7h3v-7h3l1-3h-4V9c0-.6.4-1 1-1Z"/></svg></a>
            <a href="{{ site.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/></svg></a>
            <a href="{{ site.linkedin_url }}" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 10v7M7 7v.01M11 17v-4.5a2.5 2.5 0 0 1 5 0V17M11 10v7"/></svg></a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
