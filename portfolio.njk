---
layout: base.njk
title: Portfolio — Film & Photography Work | Shot Okay Films
permalink: /portfolio/
---

<div class="page-header wrap">

  <span class="eyebrow mono">
    SELECTED WORK
  </span>

  <h1>
    Stories we've made <span class="accent">Shot Okay.</span>
  </h1>

  <p>
    Explore selected films, photography, campaigns, and visual stories created
    for brands, people, products, spaces, and original ideas.
  </p>

</div>


<div class="wrap">

  {% for s in services.services %}

    <div class="portfolio-category">

      <h2>
        {{ s.name }}
      </h2>

      <span class="cat-count mono">
        {{ s.cam }}
      </span>


      <div class="portfolio-grid">

        {% for project in collections.portfolioProjects %}

          {% if project.data.category == s.name %}


            {# ===============================================
               VIDEO PROJECT
            ================================================ #}

            {% if project.data.video %}

              <div
                class="pf-card video-project"
                data-video="{{ project.data.video }}"
                role="button"
                tabindex="0"
                aria-label="Play {{ project.data.title }}"
              >

                <div
                  class="pf-screen"
                  {% if project.data.thumbnail %}
                    style="
                      background-image: url('{{ project.data.thumbnail }}');
                      background-size: cover;
                      background-position: center;
                      background-repeat: no-repeat;
                    "
                  {% endif %}
                >

                  <span class="pf-label mono">
                    ▶ PLAY
                  </span>

                </div>


                <div class="pf-meta">

                  <span class="pf-name">
                    {{ project.data.title }}
                  </span>

                  <span class="pf-tag mono">

                    {% if project.data.date %}
                      {{ project.data.date }}
                    {% else %}
                      {{ project.data.category }}
                    {% endif %}

                  </span>

                </div>

              </div>



            {# ===============================================
               PHOTOGRAPHY / GALLERY PROJECT
            ================================================ #}

            {% elif project.data.gallery %}

              <a
                href="{{ project.url }}"
                class="pf-card gallery-project"
                aria-label="View {{ project.data.title }}"
              >

                <div
                  class="pf-screen"
                  {% if project.data.thumbnail %}
                    style="
                      background-image: url('{{ project.data.thumbnail }}');
                      background-size: cover;
                      background-position: center;
                      background-repeat: no-repeat;
                    "
                  {% endif %}
                >

                  <span class="pf-label mono">
                    VIEW PROJECT
                  </span>

                </div>


                <div class="pf-meta">

                  <span class="pf-name">
                    {{ project.data.title }}
                  </span>

                  <span class="pf-tag mono">

                    {% if project.data.date %}
                      {{ project.data.date }}
                    {% else %}
                      {{ project.data.category }}
                    {% endif %}

                  </span>

                </div>

              </a>



            {# ===============================================
               PROJECT WITHOUT VIDEO OR GALLERY
            ================================================ #}

            {% else %}

              <div class="pf-card">

                <div
                  class="pf-screen"
                  {% if project.data.thumbnail %}
                    style="
                      background-image: url('{{ project.data.thumbnail }}');
                      background-size: cover;
                      background-position: center;
                      background-repeat: no-repeat;
                    "
                  {% endif %}
                >

                  <span class="pf-label mono">
                    PROJECT
                  </span>

                </div>


                <div class="pf-meta">

                  <span class="pf-name">
                    {{ project.data.title }}
                  </span>

                  <span class="pf-tag mono">

                    {% if project.data.date %}
                      {{ project.data.date }}
                    {% else %}
                      {{ project.data.category }}
                    {% endif %}

                  </span>

                </div>

              </div>

            {% endif %}


          {% endif %}

        {% endfor %}

      </div>

    </div>

  {% endfor %}

</div>



<!-- ========================================================
     VIDEO POPUP
========================================================= -->

<div
  class="video-modal"
  id="videoModal"
  aria-hidden="true"
>

  <button
    class="video-modal-close"
    id="videoModalClose"
    type="button"
    aria-label="Close video"
  >
    ×
  </button>


  <div class="video-modal-content">

    <iframe
      id="videoPlayer"
      src=""
      title="Shot Okay Films project video"
      allow="autoplay; fullscreen; picture-in-picture"
      allowfullscreen
    ></iframe>

  </div>

</div>



<!-- ========================================================
     CTA
========================================================= -->

<section class="cta-banner">

  <div class="wrap">

    <h2>
      Have an idea worth shooting?
    </h2>


    <div class="cta-row">

      <a
        href="/contact/"
        class="btn-rec"
      >
        Start a Project
      </a>


      <a
        href="https://wa.me/{{ site.whatsapp }}"
        target="_blank"
        rel="noopener"
        class="tel-link"
      >
        or WhatsApp us directly →
      </a>

    </div>

  </div>

</section>



<!-- ========================================================
     VIDEO PLAYER SCRIPT
========================================================= -->

<script>

document.addEventListener("DOMContentLoaded", () => {

  const modal = document.getElementById("videoModal");
  const player = document.getElementById("videoPlayer");
  const closeButton = document.getElementById("videoModalClose");
  const videoProjects = document.querySelectorAll(".video-project");


  /*
  ============================================================
  CREATE EMBED URL
  ============================================================
  */

  function getEmbedUrl(videoUrl) {

    if (!videoUrl) {
      return "";
    }


    /*
    -------------------------
    YOUTUBE
    -------------------------
    */

    if (
      videoUrl.includes("youtube.com") ||
      videoUrl.includes("youtu.be")
    ) {

      let videoId = "";


      try {

        const url = new URL(videoUrl);


        /*
        YouTube short link
        */

        if (url.hostname.includes("youtu.be")) {

          videoId = url.pathname
            .split("/")
            .filter(Boolean)[0];

        }


        /*
        YouTube Shorts
        */

        else if (url.pathname.includes("/shorts/")) {

          videoId = url.pathname
            .split("/shorts/")[1]
            .split("/")[0];

        }


        /*
        Standard YouTube link
        */

        else {

          videoId = url.searchParams.get("v");

        }

      }

      catch (error) {

        console.error(
          "Invalid YouTube URL:",
          videoUrl
        );

      }


      if (videoId) {

        return (
          "https://www.youtube.com/embed/" +
          videoId +
          "?autoplay=1&rel=0"
        );

      }

    }



    /*
    -------------------------
    VIMEO
    -------------------------
    */

    if (videoUrl.includes("vimeo.com")) {

      try {

        const url = new URL(videoUrl);

        const pathParts = url.pathname
          .split("/")
          .filter(Boolean);


        const videoId = pathParts.find(
          part => /^\d+$/.test(part)
        );


        if (videoId) {

          return (
            "https://player.vimeo.com/video/" +
            videoId +
            "?autoplay=1"
          );

        }

      }

      catch (error) {

        console.error(
          "Invalid Vimeo URL:",
          videoUrl
        );

      }

    }


    return "";

  }



  /*
  ============================================================
  OPEN VIDEO
  ============================================================
  */

  function openVideo(card) {

    const videoUrl = card.dataset.video;

    const embedUrl = getEmbedUrl(videoUrl);


    if (!embedUrl) {

      console.error(
        "Unable to create video embed URL:",
        videoUrl
      );

      return;

    }


    player.src = embedUrl;

    modal.classList.add("active");

    modal.setAttribute(
      "aria-hidden",
      "false"
    );

    document.body.style.overflow = "hidden";

  }



  /*
  ============================================================
  VIDEO PROJECT INTERACTIONS
  ============================================================
  */

  videoProjects.forEach(card => {

    card.addEventListener(
      "click",
      () => {

        openVideo(card);

      }
    );


    card.addEventListener(
      "keydown",
      event => {

        if (
          event.key === "Enter" ||
          event.key === " "
        ) {

          event.preventDefault();

          openVideo(card);

        }

      }
    );

  });



  /*
  ============================================================
  CLOSE VIDEO
  ============================================================
  */

  function closeVideo() {

    modal.classList.remove("active");

    modal.setAttribute(
      "aria-hidden",
      "true"
    );

    player.src = "";

    document.body.style.overflow = "";

  }



  closeButton.addEventListener(
    "click",
    closeVideo
  );


  modal.addEventListener(
    "click",
    event => {

      if (event.target === modal) {

        closeVideo();

      }

    }
  );


  document.addEventListener(
    "keydown",
    event => {

      if (
        event.key === "Escape" &&
        modal.classList.contains("active")
      ) {

        closeVideo();

      }

    }
  );

});

</script>
