---
layout: base.njk
title: Portfolio — Shot Okay Films
permalink: /portfolio/
---

<div class="page-header wrap">
  <span class="eyebrow mono">SELECTED WORK</span>
  <h1>A few frames from the reel</h1>
  <p>Grouped by the six kinds of shoots we do. Add new projects anytime through the CMS — they'll show up here automatically.</p>
</div>

<div class="wrap">

  {% for s in services.services %}

    <div class="portfolio-category">

      <h2>{{ s.name }}</h2>

      <span class="cat-count mono">
        {{ s.cam }}
      </span>

      <div class="portfolio-grid">

        {% for project in collections.portfolioProjects %}

          {% if project.data.category == s.name %}

            <div
              class="pf-card video-project"
              {% if project.data.video %}
              data-video="{{ project.data.video }}"
              {% endif %}
            >

              <div
                class="pf-screen"
                {% if project.data.thumbnail %}
                style="
                  background-image: url('{{ project.data.thumbnail }}');
                  background-size: cover;
                  background-position: center;
                  background-repeat: no-repeat;
                "
                {% endif %}
              >

                {% if project.data.video %}
                  <span class="pf-label mono">▶ PLAY</span>
                {% else %}
                  <span class="pf-label mono">REEL</span>
                {% endif %}

              </div>

              <div class="pf-meta">

                <span class="pf-name">
                  {{ project.data.title }}
                </span>

                <span class="pf-tag mono">
                  {% if project.data.date %}
                    {{ project.data.date }}
                  {% else %}
                    {{ project.data.category }}
                  {% endif %}
                </span>

              </div>

            </div>

          {% endif %}

        {% endfor %}

      </div>

    </div>

  {% endfor %}

</div>


<!-- VIDEO POPUP -->

<div class="video-modal" id="videoModal">

  <button
    class="video-modal-close"
    id="videoModalClose"
    aria-label="Close video"
  >
    ×
  </button>

  <div class="video-modal-content">

    <iframe
      id="videoPlayer"
      src=""
      allow="autoplay; fullscreen; picture-in-picture"
      allowfullscreen
    ></iframe>

  </div>

</div>


<section class="cta-banner">

  <div class="wrap">

    <h2>Want to see more?</h2>

    <div class="cta-row">

      <a
        href="https://wa.me/{{ site.whatsapp }}"
        target="_blank"
        rel="noopener"
        class="btn-rec"
      >
        Ask us on WhatsApp
      </a>

    </div>

  </div>

</section>


<script>

const modal = document.getElementById("videoModal");
const player = document.getElementById("videoPlayer");
const closeButton = document.getElementById("videoModalClose");

document.querySelectorAll(".video-project").forEach(card => {

  card.addEventListener("click", () => {

    const videoUrl = card.dataset.video;

    if (!videoUrl) return;

    let embedUrl = "";

    /* YOUTUBE */

    if (
      videoUrl.includes("youtube.com") ||
      videoUrl.includes("youtu.be")
    ) {

      let videoId = "";

      if (videoUrl.includes("youtu.be")) {

        videoId = videoUrl
          .split("youtu.be/")[1]
          .split("?")[0];

      } else {

        try {

          const url = new URL(videoUrl);

          videoId = url.searchParams.get("v");

        } catch (error) {

          console.error("Invalid YouTube URL");

        }

      }

      if (videoId) {

        embedUrl =
          "https://www.youtube.com/embed/" +
          videoId +
          "?autoplay=1&rel=0";

      }

    }


    /* VIMEO */

    else if (videoUrl.includes("vimeo.com")) {

      const videoId = videoUrl
        .split("/")
        .filter(Boolean)
        .pop()
        .split("?")[0];

      embedUrl =
        "https://player.vimeo.com/video/" +
        videoId +
        "?autoplay=1";

    }


    /* OPEN PLAYER */

    if (embedUrl) {

      player.src = embedUrl;

      modal.classList.add("active");

      document.body.style.overflow = "hidden";

    }

  });

});


function closeVideo() {

  modal.classList.remove("active");

  player.src = "";

  document.body.style.overflow = "";

}


closeButton.addEventListener(
  "click",
  closeVideo
);


modal.addEventListener("click", event => {

  if (event.target === modal) {

    closeVideo();

  }

});


document.addEventListener("keydown", event => {

  if (event.key === "Escape") {

    closeVideo();

  }

});

</script>
