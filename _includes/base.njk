<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>{{ title }}</title>

  <meta
    name="description"
    content="{{ description or site.tagline }}"
  >


  <!-- =====================================================
       GOOGLE FONTS
  ====================================================== -->

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  >

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  >

  <link
    href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
    rel="stylesheet"
  >


  <!-- =====================================================
       MAIN STYLESHEET
  ====================================================== -->

  <link
    rel="stylesheet"
    href="/css/style.css"
  >

</head>


<body data-whatsapp="{{ site.whatsapp }}">


  <!-- =====================================================
       GLOBAL FILM GRAIN
  ====================================================== -->

  <div
    class="grain-overlay"
    aria-hidden="true"
  ></div>



  <!-- =====================================================
       NAVIGATION
  ====================================================== -->

  <header class="nav">

    <div class="nav-inner">


      <!-- BRAND / RECORDING STATUS -->

      <div class="nav-brand">

 <span class="nav-rec" aria-hidden="true">
          <span class="nav-rec-dot"></span>
        </span>

        <a
          href="/"
          class="wordmark"
          aria-label="{{ site.name }} — Home"
        >

          <img
            class="brand-logo"
            src="/assets/logo.png"
            alt="{{ site.name }} logo"
          >

        </a>


      </div>



      <!-- DESKTOP NAVIGATION -->

      <nav
        class="site-links"
        aria-label="Primary navigation"
      >

        <a
          href="/"
          {% if page.url == "/" %}
            aria-current="page"
          {% endif %}
        >
          Home
        </a>


        <a
          href="/services/"
          {% if page.url == "/services/" %}
            aria-current="page"
          {% endif %}
        >
          Services
        </a>


        <a
          href="/portfolio/"
          {% if page.url == "/portfolio/" %}
            aria-current="page"
          {% endif %}
        >
          Projects
        </a>


        <a
          href="/about/"
          {% if page.url == "/about/" %}
            aria-current="page"
          {% endif %}
        >
          About Us
        </a>


        <a
          href="/contact/"
          {% if page.url == "/contact/" %}
            aria-current="page"
          {% endif %}
        >
          Contact Us
        </a>

      </nav>



      <!-- NAVIGATION ACTIONS -->

      <div class="nav-actions">


        <!-- CALL BUTTON -->

        <a
          href="tel:+{{ site.phone_e164 }}"
          class="nav-call"
          aria-label="Call us"
        >

          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >

            <path
              d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.5 2.1L8 10a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.9.6 2.9.7a2 2 0 0 1 1.7 2Z"
            />

          </svg>

        </a>



        <!-- GET A QUOTE -->

        <a
          href="/contact/"
          class="nav-cta"
        >
          Get a Quote
        </a>

      </div>

    </div>

  </header>



  <!-- =====================================================
       PAGE CONTENT
  ====================================================== -->

  {{ content | safe }}



  <!-- =====================================================
       FOOTER
  ====================================================== -->

  <footer>


    <!-- FOOTER LOGO -->

    <img
      class="brand-logo footer-logo"
      src="/assets/logo.png"
      alt="{{ site.name }} logo"
    >



    <!-- END TRANSMISSION -->

    <p class="tagline">
      // END OF TRANSMISSION //
    </p>



    <!-- SOCIAL MEDIA -->

    <div class="social-row">


      <!-- FACEBOOK -->

      <a
        href="{{ site.facebook_url }}"
        target="_blank"
        rel="noopener"
        aria-label="Facebook"
      >

        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
        >

          <path
            d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v7h3v-7h3l1-3h-4V9c0-.6.4-1 1-1Z"
          />

        </svg>

      </a>



      <!-- INSTAGRAM -->

      <a
        href="{{ site.instagram_url }}"
        target="_blank"
        rel="noopener"
        aria-label="Instagram"
      >

        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
        >

          <rect
            x="3"
            y="3"
            width="18"
            height="18"
            rx="5"
          />

          <circle
            cx="12"
            cy="12"
            r="4"
          />

          <circle
            cx="17.5"
            cy="6.5"
            r="1"
          />

        </svg>

      </a>



      <!-- LINKEDIN -->

      <a
        href="{{ site.linkedin_url }}"
        target="_blank"
        rel="noopener"
        aria-label="LinkedIn"
      >

        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
        >

          <rect
            x="3"
            y="3"
            width="18"
            height="18"
            rx="2"
          />

          <path
            d="M7 10v7M7 7v.01M11 17v-4.5a2.5 2.5 0 0 1 5 0V17M11 10v7"
          />

        </svg>

      </a>

    </div>



    <!-- ADDRESS -->

    <p class="footer-address mono">
      {{ site.address_line1 }}
      {{ site.address_line2 }}
    </p>



    <!-- BUSINESS HOURS -->

    <p class="footer-hours mono">
      {{ site.hours }}
    </p>



    <!-- COPYRIGHT -->

    <div class="copyright">
      {{ site.name | upper }} © 2026
    </div>


  </footer>



  <!-- =====================================================
       MAIN WEBSITE JAVASCRIPT
  ====================================================== -->

  <script src="/js/main.js"></script>



  <!-- =====================================================
       INTERACTIVE AMBIENT BACKGROUND

       Controls:
       - Cursor-following amber light
       - Smooth cursor interpolation
       - Scroll-reactive background movement
       - Film grain movement
  ====================================================== -->

  <script>

    document.addEventListener("DOMContentLoaded", () => {


      const root = document.documentElement;


      /*
      ========================================================
      CURSOR POSITION
      ========================================================
      */


      let targetX = 50;
      let targetY = 30;

      let currentX = 50;
      let currentY = 30;



      /*
      Track mouse / pointer
      */


      window.addEventListener(

        "pointermove",

        (event) => {


          targetX =
            (event.clientX / window.innerWidth)
            * 100;


          targetY =
            (event.clientY / window.innerHeight)
            * 100;


        },

        {
          passive: true
        }

      );



      /*
      Smooth cursor movement

      Instead of the glow snapping directly
      to the cursor, it follows with a subtle
      cinematic delay.
      */


      function animateCursorGlow() {


        currentX +=
          (targetX - currentX)
          * 0.075;


        currentY +=
          (targetY - currentY)
          * 0.075;



        root.style.setProperty(

          "--cursor-x",

          currentX + "%"

        );



        root.style.setProperty(

          "--cursor-y",

          currentY + "%"

        );



        requestAnimationFrame(
          animateCursorGlow
        );


      }



      /*
      Start cursor animation
      */


      animateCursorGlow();



      /*
      ========================================================
      SCROLL-REACTIVE BACKGROUND
      ========================================================
      */


      let scrollTicking = false;



      window.addEventListener(

        "scroll",

        () => {


          if (!scrollTicking) {


            window.requestAnimationFrame(

              () => {


                /*
                Slow movement relative to scroll.

                The maximum is intentionally limited
                so the background doesn't drift too far.
                */


                const scrollShift =

                  Math.min(

                    window.scrollY * 0.045,

                    90

                  );



                root.style.setProperty(

                  "--scroll-shift",

                  scrollShift + "px"

                );



                scrollTicking = false;


              }

            );



            scrollTicking = true;


          }


        },

        {
          passive: true
        }

      );



      /*
      ========================================================
      RESET GLOW WHEN CURSOR LEAVES WINDOW
      ========================================================
      */


      document.documentElement.addEventListener(

        "mouseleave",

        () => {


          targetX = 50;

          targetY = 30;


        }

      );



    });

  </script>


</body>

</html>
