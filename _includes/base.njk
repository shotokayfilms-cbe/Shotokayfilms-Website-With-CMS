<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<meta name="description" content="{{ description or site.tagline }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body data-whatsapp="{{ site.whatsapp }}">
<div class="grain-overlay"></div>

<header class="nav">
  <div class="nav-inner">
    <a href="/" class="wordmark"><span class="tally-dot on blink"></span><img class="brand-logo" src="/assets/logo.png" alt="{{ site.name }} logo"></a>
    <nav class="site-links" aria-label="Primary navigation">
      <a href="/"{% if page.url == "/" %} aria-current="page"{% endif %}>Home</a>
      <a href="/services/"{% if page.url == "/services/" %} aria-current="page"{% endif %}>Services</a>
      <a href="/portfolio/"{% if page.url == "/portfolio/" %} aria-current="page"{% endif %}>Projects</a>
      <a href="/about/"{% if page.url == "/about/" %} aria-current="page"{% endif %}>About Us</a>
      <a href="/contact/"{% if page.url == "/contact/" %} aria-current="page"{% endif %}>Contact Us</a>
    </nav>
    <div class="nav-actions">
      <a href="tel:+{{ site.phone_e164 }}" class="nav-call" aria-label="Call us"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.5 2.1L8 10a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.9.6 2.9.7a2 2 0 0 1 1.7 2Z"/></svg></a>
      <a href="/contact/" class="nav-cta">Get a Quote</a>
    </div>
  </div>
</header>

{{ content | safe }}

<footer>
  <img class="brand-logo footer-logo" src="/assets/logo.png" alt="{{ site.name }} logo">
  <p class="tagline">// END OF TRANSMISSION //</p>
  <div class="social-row">
    <a href="{{ site.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v7h3v-7h3l1-3h-4V9c0-.6.4-1 1-1Z"/></svg></a>
    <a href="{{ site.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/></svg></a>
    <a href="{{ site.linkedin_url }}" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 10v7M7 7v.01M11 17v-4.5a2.5 2.5 0 0 1 5 0V17M11 10v7"/></svg></a>
  </div>
  <p class="footer-address mono">{{ site.address_line1 }} {{ site.address_line2 }}</p>
  <p class="footer-hours mono">{{ site.hours }}</p>
  <div class="copyright">{{ site.name | upper }} © 2026</div>
</footer>

<script src="/js/main.js"></script>
</body>
</html>
